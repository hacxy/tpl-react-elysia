{
  "name": "fullstack-template",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:web": "bun --filter web dev",
    "dev:server": "bun --filter server dev",
    "build": "bun --filter '*' build",
    "build:web": "bun --filter web build",
    "build:server": "bun --filter server build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun --filter '*' test",
    "test:web": "bun --filter web test",
    "test:server": "bun --filter server test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "*": "eslint --fix",
    "*.{js,ts,jsx,tsx,json,css,md}": "prettier --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}

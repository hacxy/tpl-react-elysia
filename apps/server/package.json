{
  "name": "server",
  "version": "1.0.0",
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch src/app.ts",
    "build": "BUN_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-darwin-arm64 --outfile server ./src/index.ts",
    "build:linux": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile server ./src/index.ts",
    "build:linux-arm64": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-linux-arm64 --outfile server ./src/index.ts",
    "build:windows": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-windows-x64 --outfile server.exe ./src/index.ts",
    "prisma:generate": "bunx prisma generate",
    "prisma:push": "bunx prisma db push",
    "prisma:seed": "bun run prisma/seed.ts",
    "prisma:migrate": "bunx prisma migrate dev",
    "prisma:migrate:prod": "bunx prisma migrate deploy",
    "prisma:reset": "bunx prisma migrate reset"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@elysiajs/static": "^1.4.10",
    "@libsql/client": "^0.17.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "elysia": "^1.4.29",
    "elysia-ip": "^2.0.0",
    "logixlysia": "^6.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "typescript": "^5.9.3"
  },
  "module": "src/index.js"
}
